{
  "name": "adora-subscription-reconciler",
  "version": "1.0.0",
  "private": true,
  "description": "Premium entitlement reconciler across store, carrier and marketplace channels",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "mkdir -p dist/db && cp -r src/db/migrations dist/db/",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "mock-carrier": "tsx src/mock/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
